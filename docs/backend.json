
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Personal Space application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "preferredThemeId": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "description": "A high-level container for notes.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name"]
    },
    "Label": {
      "title": "Label",
      "type": "object",
      "description": "A category within a project.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["id", "name"]
    },
    "Note": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Note",
      "type": "object",
      "description": "Represents a single note created by a user.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "metadata": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "isPinned": { "type": "boolean" },
        "isArchived": { "type": "boolean" },
        "isDeleted": { "type": "boolean" },
        "projectId": { "type": "string", "description": "ID of the Project document" },
        "labelId": { "type": "string", "description": "ID of the Label document" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "title", "content", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and settings."
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/Project" },
      "description": "User projects."
    },
    "/users/{userId}/projects/{projectId}/labels/{labelId}": {
      "schema": { "$ref": "#/backend/entities/Label" },
      "description": "Labels within a project."
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": { "$ref": "#/backend/entities/Note" },
      "description": "User-specific notes."
    }
  }
}
