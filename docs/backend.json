{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the NoteWave application, associated with authentication and preferences.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The display name of the user."
        },
        "preferredThemeId": {
          "type": "string",
          "description": "Reference to the Theme entity."
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "Note": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Note",
      "type": "object",
      "description": "Represents a single note created by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Note entity."
        },
        "userId": {
          "type": "string",
          "description": "Owner of the note."
        },
        "title": {
          "type": "string",
          "description": "The title of the note."
        },
        "content": {
          "type": "string",
          "description": "The main text content."
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp indicating when the note was created."
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp indicating when the note was last updated."
        },
        "isPinned": {
          "type": "boolean",
          "description": "Flag for pinned notes."
        }
      },
      "required": [
        "id",
        "userId",
        "title",
        "content",
        "updatedAt"
      ]
    },
    "Theme": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Theme",
      "type": "object",
      "description": "Defines application theme characteristics.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "primary": {
          "type": "string",
          "description": "HSL primary color (e.g. '199 68% 77%')"
        },
        "background": {
          "type": "string",
          "description": "HSL background color"
        },
        "accent": {
          "type": "string",
          "description": "HSL accent color"
        }
      },
      "required": [
        "id",
        "name",
        "primary",
        "background",
        "accent"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and settings."
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": { "$ref": "#/backend/entities/Note" },
      "description": "User-specific notes."
    },
    "/themes/{themeId}": {
      "schema": { "$ref": "#/backend/entities/Theme" },
      "description": "Global predefined themes."
    }
  }
}
